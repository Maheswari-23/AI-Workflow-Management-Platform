{
  "version": 2,
  "name": "orchestr",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://your-backend-domain.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "BACKEND_URL": "https://your-backend-domain.railway.app",
    "NEXT_PUBLIC_API_URL": "https://your-backend-domain.railway.app"
  },
  "regions": ["iad1"],
  "github": {
    "silent": true
  }
}
